      "parameters": {
        "jsCode": "const email = $input.item.json;\n\n// Uncomment this line to see everything — useful for debugging\n// return email;\n\nconst subject = \n  email.subject ||\n  email.Subject ||\n  email.headers?.subject ||\n  email.payload?.headers?.find(h => h.name === 'Subject')?.value ||\n  'No Subject';\n\nconst sender =\n  email.from ||\n  email.From ||\n  email.sender ||\n  email.headers?.from ||\n  email.payload?.headers?.find(h => h.name === 'From')?.value ||\n  email.from?.value?.[0]?.address ||\n  'Unknown Sender';\n\nconst body =\n  email.text ||\n  email.body ||\n  email.snippet ||\n  email.textPlain ||\n  '';\n\nreturn {\n  subject: subject,\n  sender: sender,\n  body: body.slice(0, 1500),\n  emailId: email.id || email.messageId || '',\n  date: email.date || email.internalDate || new Date().toISOString()\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        208,
        0
