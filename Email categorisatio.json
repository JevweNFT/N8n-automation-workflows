    {
      "parameters": {
        "modelId": {
          "__rl": true,
          "value": "gpt-4.1-mini",
          "mode": "list",
          "cachedResultName": "GPT-4.1-MINI"
        },
        "responses": {
          "values": [
            {
              "content": "=You are an email classification assistant for a business.\n\nClassify the following email into EXACTLY ONE of these categories:\n- Sales\n- Customer Service\n- Human Resources\n- Finance\n- Operations\n- Other\n\nEmail Subject: {{ $json.subject }}\nFrom: {{ $json.sender }}\nBody: {{ $json.body }}\n\nRespond with ONLY a JSON object in this exact format (no extra text):\n{\n  \"category\": \"Sales\",\n  \"confidence\": \"High\",\n  \"reason\": \"Brief one-line reason\"\n}"
            }
          ]
        },
        "builtInTools": {},
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 2.1,
      "position": [
        416,
        0
      ],
      "id": "dc2e0f7e-e877-441f-9554-cdceb0838fa9",
      "name": "Message a model",
      "credentials": {
        "openAiApi": {
          "id": "KnQU8xBmKJD2weu6",
          "name": "n8n free OpenAI API credits"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const data = $input.item.json;\n\nconst aiResponse = data.output?.[0]?.content?.[0]?.text || '';\n\nif (!aiResponse) {\n  return { debug: JSON.stringify(data), category: 'Other', confidence: 'Low', reason: 'No AI response found' };\n}\n\nlet parsed;\ntry {\n  parsed = JSON.parse(aiResponse);\n} catch (e) {\n  const categoryMatch = aiResponse.match(/\"category\"\\s*:\\s*\"([^\"]+)\"/);\n  const confidenceMatch = aiResponse.match(/\"confidence\"\\s*:\\s*\"([^\"]+)\"/);\n  const reasonMatch = aiResponse.match(/\"reason\"\\s*:\\s*\"([^\"]+)\"/);\n\n  parsed = {\n    category: categoryMatch?.[1] || 'Other',\n    confidence: confidenceMatch?.[1] || 'Low',\n    reason: reasonMatch?.[1] || 'Could not parse response'\n  };\n}\n\nreturn {\n  emailId: data.emailId || '',\n  subject: data.subject || '',\n  sender: data.sender || '',\n  date: data.date || '',\n  category: parsed.category,\n  confidence: parsed.confidence,\n  reason: parsed.reason\n};"
      },
